# Copy this file to ".env" and fill in your values.
# Never commit the real .env — it contains a secret token.

# Azure DevOps organization URL.
AZP_URL=https://dev.azure.com/your-org

# Personal Access Token with "Agent Pools (read, manage)" scope.
AZP_TOKEN=your-pat-here

# Agent pool to join (must already exist in Azure DevOps).
AZP_POOL=Default

# Work directory inside the container (optional).
AZP_WORK=_work
